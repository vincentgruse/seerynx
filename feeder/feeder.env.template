# Seerynx Feeder Environment Configuration
# Copy to feeder.env and fill in values
# sudo cp /etc/seerynx/feeder.env.template /etc/seerynx/feeder.env

MQTT_HOST=
MQTT_PORT=31883
MQTT_USER=seerynx
MQTT_PASSWORD=

# Camera
CAMERA_WIDTH=1920
CAMERA_HEIGHT=1080
CAMERA_FRAMERATE=10

# Motion detection
MOTION_THRESHOLD=25
MOTION_MIN_AREA=1500
MOTION_SUSTAIN_FRAMES=3
BURST_COUNT=3
MOTION_COOLDOWN=10
